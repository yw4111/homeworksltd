---
import { business } from '../data/business';
import { withBase } from '../lib/paths';

const nav = [
  { href: '/services/', label: 'Services' },
  { href: '/about/', label: 'About' },
  { href: '/projects/', label: 'Projects' },
  { href: '/contact/', label: 'Contact' },
];
const current = Astro.url.pathname;
---

<header class="site-header">
  <div class="wrap site-header__inner">
    <a href={withBase('/')} class="wordmark" aria-label={`${business.name} home`}>
      <span class="wordmark__name">Home Works</span>
      <span class="wordmark__stamp">Est. {business.founded}</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a
                href={withBase(item.href)}
                aria-current={current.startsWith(withBase(item.href)) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a class="site-header__phone" href={`tel:${business.phoneHref}`}>
      <span class="visually-hidden">Call </span>{business.phoneDisplay}
    </a>
  </div>
</header>

<style>
  .site-header {
    background: var(--petrol-dark);
    color: var(--stone);
    border-bottom: 3px solid var(--amber);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding-block: 0.7rem;
  }

  .wordmark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--white);
    margin-right: auto;
  }

  .wordmark__name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.3rem;
    letter-spacing: -0.01em;
  }

  .wordmark__stamp {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    border: 1px solid var(--amber);
    border-radius: 2px;
    padding: 0.1rem 0.35rem;
  }

  .site-nav ul {
    list-style: none;
    display: flex;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .site-nav a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--stone);
    text-decoration: none;
    padding: 0.4rem 0.6rem;
    border-radius: 2px;
  }

  .site-nav a:hover,
  .site-nav a[aria-current='page'] {
    color: var(--white);
    background: rgba(255, 255, 255, 0.08);
  }

  .site-nav a[aria-current='page'] {
    box-shadow: inset 0 -2px 0 var(--amber);
  }

  .site-header__phone {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--white);
    text-decoration: none;
    white-space: nowrap;
    border: 1.5px solid var(--amber);
    border-radius: 2px;
    padding: 0.35rem 0.7rem;
  }

  .site-header__phone:hover {
    background: var(--amber);
    color: var(--ink);
  }

  @media (max-width: 33rem) {
    .wordmark {
      margin-right: 0;
      width: 100%;
    }
    .site-header__phone {
      margin-left: auto;
    }
  }
</style>
