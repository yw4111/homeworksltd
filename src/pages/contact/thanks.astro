---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { business } from '../../data/business';
import { withBase } from '../../lib/paths';
---

<BaseLayout
  title="Thanks | Home Works Ltd"
  description="Thank you for your booking request to Home Works Ltd. We will be in touch during opening hours, Monday to Friday 9am to 5pm."
  path="/contact/thanks/"
>
  <section class="section section--petrol">
    <div class="wrap">
      <span class="eyebrow">Booking request</span>
      <h1>Thanks, we have your details</h1>
      <p class="lede" style="color: var(--stone);">
        We will get back to you during opening hours, {business.hours.display}.
        If it is urgent, call {business.phoneDisplay}.
      </p>
      <p>
        <a class="btn btn--primary" href={withBase('/')}>Back to home</a>
      </p>
    </div>
  </section>
</BaseLayout>
